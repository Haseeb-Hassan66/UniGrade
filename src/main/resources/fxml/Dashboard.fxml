<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="ui.DashboardController"
           alignment="CENTER"
           style="-fx-background-color: linear-gradient(to bottom right, #141423, #4C1D95);">

    <!-- Center content only (card) -->
    <VBox alignment="CENTER" spacing="20"
          style="-fx-background-color: #1F1F33; -fx-padding: 36 30; -fx-background-radius: 22;">
        
        <effect>
            <DropShadow radius="30" offsetY="14" color="#000000AA"/>
        </effect>

        <Label fx:id="welcomeLabel" text="Welcome, User!"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>

        <HBox alignment="CENTER" spacing="20">
            <Button text="Add Grade"
                    style="-fx-background-color: linear-gradient(to right, #7C3AED, #5B21B6); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 14; -fx-padding: 8 25;"/>
            <Button text="View Reports"
                    style="-fx-background-color: linear-gradient(to right, #7C3AED, #5B21B6); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 14; -fx-padding: 8 25;"/>
        </HBox>
    </VBox>

</StackPane>