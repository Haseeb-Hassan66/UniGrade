<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
    fx:controller="ui.SemesterResultController"
    style="-fx-background-color: #14142B;">

    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
            style="-fx-background-color: #1F1F33; -fx-padding: 20;">
            <Button fx:id="backButton" text="← Back" onAction="#handleBack"
                style="-fx-background-color: transparent; -fx-text-fill: #A78BFA; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" />

            <Region HBox.hgrow="ALWAYS" />

            <Label text="Semester Result Card"
                style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />

            <Region HBox.hgrow="ALWAYS" />
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
            <VBox spacing="25" style="-fx-padding: 30;">

                <!-- Header Card: Student & Semester Info -->
                <VBox spacing="15"
                    style="-fx-background-color: #1F1F33; -fx-padding: 25; -fx-background-radius: 18;">
                    
                    <HBox alignment="CENTER" spacing="30">
                        <VBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Student Information"
                                style="-fx-text-fill: #A5A3C7; -fx-font-size: 12px; -fx-font-weight: bold;" />
                            <Label fx:id="studentNameLabel" text="Student Name"
                                style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
                            <Label fx:id="departmentLabel" text="Department"
                                style="-fx-text-fill: #BDB7E2; -fx-font-size: 14px;" />
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <VBox spacing="8" alignment="CENTER">
                            <Label text="Semester"
                                style="-fx-text-fill: #A5A3C7; -fx-font-size: 12px; -fx-font-weight: bold;" />
                            <Label fx:id="semesterNameLabel" text="Fall 2024"
                                style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
                        </VBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <VBox spacing="8" alignment="CENTER_RIGHT">
                            <Label text="GPA"
                                style="-fx-text-fill: #A5A3C7; -fx-font-size: 12px; -fx-font-weight: bold;" />
                            <Label fx:id="gpaLabel" text="0.00"
                                style="-fx-text-fill: #A78BFA; -fx-font-size: 32px; -fx-font-weight: bold;" />
                            <Label fx:id="gradeClassLabel" text="First Class"
                                style="-fx-text-fill: #10B981; -fx-font-size: 12px; -fx-font-weight: bold;" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Subjects Table -->
                <VBox spacing="15"
                    style="-fx-background-color: #1F1F33; -fx-padding: 25; -fx-background-radius: 18;">
                    
                    <Label text="Subject-wise Performance"
                        style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

                    <!-- Table Header -->
                    <HBox spacing="10" style="-fx-padding: 10 0;">
                        <Label text="Subject" prefWidth="200"
                            style="-fx-text-fill: #A5A3C7; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label text="Credits" prefWidth="60" alignment="CENTER"
                            style="-fx-text-fill: #A5A3C7; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <Label text="Theory" prefWidth="80" alignment="CENTER"
                            style="-fx-text-fill: #A5A3C7; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <Label text="Practical" prefWidth="80" alignment="CENTER"
                            style="-fx-text-fill: #A5A3C7; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <Label text="Grade" prefWidth="60" alignment="CENTER"
                            style="-fx-text-fill: #A5A3C7; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <Label text="Points" prefWidth="60" alignment="CENTER"
                            style="-fx-text-fill: #A5A3C7; -fx-font-size: 13px; -fx-font-weight: bold;" />
                    </HBox>

                    <!-- Divider -->
                    <Separator style="-fx-background-color: #2D2D44;" />

                    <!-- Dynamic Subject Rows -->
                    <VBox fx:id="subjectRowsContainer" spacing="10" />

                    <!-- Divider -->
                    <Separator style="-fx-background-color: #2D2D44;" />

                    <!-- Summary Row -->
                    <HBox spacing="10" style="-fx-padding: 15 0 0 0;">
                        <Label text="Total" prefWidth="200"
                            style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="totalCreditsLabel" text="0" prefWidth="60" alignment="CENTER"
                            style="-fx-text-fill: #A78BFA; -fx-font-size: 15px; -fx-font-weight: bold;" />
                        <Label text="-" prefWidth="80" alignment="CENTER"
                            style="-fx-text-fill: #7D7A9C; -fx-font-size: 15px;" />
                        <Label text="-" prefWidth="80" alignment="CENTER"
                            style="-fx-text-fill: #7D7A9C; -fx-font-size: 15px;" />
                        <Label text="-" prefWidth="60" alignment="CENTER"
                            style="-fx-text-fill: #7D7A9C; -fx-font-size: 15px;" />
                        <Label fx:id="totalQualityPointsLabel" text="0.00" prefWidth="60" alignment="CENTER"
                            style="-fx-text-fill: #A78BFA; -fx-font-size: 15px; -fx-font-weight: bold;" />
                    </HBox>
                </VBox>

                <!-- Footer Info -->
                <HBox spacing="20" alignment="CENTER">
                    <VBox spacing="5" alignment="CENTER"
                        style="-fx-background-color: #1F1F33; -fx-padding: 15 30; -fx-background-radius: 12;">
                        <Label text="Total Credit Hours"
                            style="-fx-text-fill: #A5A3C7; -fx-font-size: 12px;" />
                        <Label fx:id="footerCreditsLabel" text="0"
                            style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
                    </VBox>

                    <VBox spacing="5" alignment="CENTER"
                        style="-fx-background-color: #1F1F33; -fx-padding: 15 30; -fx-background-radius: 12;">
                        <Label text="Quality Points"
                            style="-fx-text-fill: #A5A3C7; -fx-font-size: 12px;" />
                        <Label fx:id="footerQualityPointsLabel" text="0.00"
                            style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
                    </VBox>

                    <VBox spacing="5" alignment="CENTER"
                        style="-fx-background-color: #1F1F33; -fx-padding: 15 30; -fx-background-radius: 12;">
                        <Label text="Semester GPA"
                            style="-fx-text-fill: #A5A3C7; -fx-font-size: 12px;" />
                        <Label fx:id="footerGPALabel" text="0.00"
                            style="-fx-text-fill: #A78BFA; -fx-font-size: 20px; -fx-font-weight: bold;" />
                    </VBox>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>