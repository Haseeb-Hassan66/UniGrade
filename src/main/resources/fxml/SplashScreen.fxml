<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
    fx:controller="ui.SplashScreenController"
    style="-fx-background-color: linear-gradient(to bottom right, #141423, #4C1D95);"
    prefWidth="900" prefHeight="600">

    <center>
        <!-- Main Content -->
        <VBox alignment="CENTER" spacing="50">
            
            <!-- Logo Circle -->
            <VBox alignment="CENTER">
                <StackPane prefWidth="200" prefHeight="200"
                    style="-fx-background-color: linear-gradient(to bottom right, #7C3AED, #5B21B6); -fx-background-radius: 100;">
                    
                    <effect>
                        <DropShadow radius="30" offsetY="12" color="#7C3AED66"/>
                    </effect>
                    
                    <!-- UG Text -->
                    <Label text="UG"
                        style="-fx-font-size: 70px; -fx-font-weight: bold; -fx-text-fill: white;"
                        translateY="5"/>
                </StackPane>
            </VBox>
            
            <!-- App Name -->
            <VBox alignment="CENTER" spacing="12">
                <Label text="UniGrade"
                    style="-fx-font-size: 64px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                
                <Label text="Academic Performance Tracker"
                    style="-fx-font-size: 18px; -fx-text-fill: #A78BFA; -fx-font-weight: 600;"/>
            </VBox>

            <!-- Loading Card -->
            <VBox alignment="CENTER" spacing="20" prefWidth="450">
                <VBox alignment="CENTER" spacing="25"
                    style="-fx-background-color: #1F1F33; -fx-background-radius: 18; -fx-padding: 35 45;">
                    
                    <effect>
                        <DropShadow radius="20" offsetY="8" color="#00000066"/>
                    </effect>
                    
                    <!-- Progress Container -->
                    <VBox alignment="CENTER" spacing="15" prefWidth="360">
                        <!-- Progress Track Background -->
                        <StackPane prefWidth="360" prefHeight="14"
                            style="-fx-background-color: #2D2D44; -fx-background-radius: 7;">
                            
                            <!-- Progress Fill -->
                            <HBox fx:id="progressFill" prefHeight="14" alignment="CENTER_LEFT">
                                <StackPane prefWidth="0" prefHeight="14"
                                    style="-fx-background-color: #7C3AED; -fx-background-radius: 7;"/>
                            </HBox>
                        </StackPane>
                        
                        <!-- Percentage -->
                        <Label fx:id="percentLabel" text="0%"
                            style="-fx-font-size: 14px; -fx-text-fill: #A78BFA; -fx-font-weight: bold;"/>
                    </VBox>
                    
                    <!-- Loading Text -->
                    <Label fx:id="loadingLabel" text="Initializing..."
                        style="-fx-font-size: 15px; -fx-text-fill: #E2E8F0; -fx-font-weight: 500;"/>
                </VBox>
            </VBox>

        </VBox>
    </center>

    <bottom>
        <!-- Developer Info -->
        <VBox alignment="CENTER" spacing="15" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="35"/>
            </padding>
            
            <VBox alignment="CENTER" spacing="10"
                style="-fx-background-color: #1F1F3350; -fx-background-radius: 12; -fx-padding: 18 40;">
                
                <Label text="Developed by Haseeb"
                    style="-fx-font-size: 14px; -fx-text-fill: #E2E8F0; -fx-font-weight: 600;"/>
                
                <Label text="github.com/haseeb"
                    style="-fx-font-size: 13px; -fx-text-fill: #A78BFA; -fx-font-weight: 500;"/>
            </VBox>
            
            <Label text="Version 1.0.0"
                style="-fx-font-size: 11px; -fx-text-fill: #7D7A9C;"/>
        </VBox>
    </bottom>

</BorderPane>