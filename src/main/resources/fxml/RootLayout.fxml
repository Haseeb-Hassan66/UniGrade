<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:id="root"
            style="
                -fx-background-color: linear-gradient(to bottom right, #141423, #4C1D95);
            ">

    <!-- Top bar -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="10"
              style="
                  -fx-background-color: transparent;
                  -fx-padding: 18 30;
              ">

            <Label text="UG"
                   style="
                       -fx-font-size: 18px;
                       -fx-font-weight: bold;
                       -fx-text-fill: #DDD6FE;
                       -fx-background-color: #312E81;
                       -fx-padding: 6 12;
                       -fx-background-radius: 10;
                   "/>

            <Label text="UniGrade"
                   style="
                       -fx-font-size: 18px;
                       -fx-font-weight: bold;
                       -fx-text-fill: #EDE9FE;
                   "/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Developer Info -->
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label text="Developed by Haseeb" 
                       style="-fx-text-fill: #E2E8F0; -fx-font-weight: bold; -fx-font-size: 12px;"/>
                <Label text="github.com/Haseeb-Hassan66" 
                       style="-fx-text-fill: #A78BFA; -fx-font-size: 11px;"/>
                <Label text="Version 1.0.0" 
                       style="-fx-text-fill: #7D7A9C; -fx-font-size: 10px;"/>
            </VBox>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <AnchorPane fx:id="contentArea"
                    style="-fx-background-color: transparent;"/>
    </center>

</BorderPane>