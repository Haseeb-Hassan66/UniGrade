<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.effect.DropShadow?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="ui.FirstRunController"
           prefWidth="900" prefHeight="600"
           alignment="CENTER"
           style="-fx-background-color: linear-gradient(to bottom right, #141423, #4C1D95);">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT"
          spacing="10"
          StackPane.alignment="TOP_CENTER"
          style="-fx-padding: 20 30;">
        
        <Label text="UG"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #DDD6FE; -fx-background-color: #312E81; -fx-padding: 6 12; -fx-background-radius: 10;"/>
        <Label text="UniGrade"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #EDE9FE;"/>
    </HBox>

    <!-- CARD -->
    <VBox alignment="CENTER"
          spacing="24"
          prefWidth="400"
          style="-fx-background-color: #1F1F33; -fx-padding: 36 30; -fx-background-radius: 22;">
        
        <effect>
            <DropShadow radius="30" offsetY="14" color="#000000AA"/>
        </effect>

        <!-- HEADING -->
        <Label text="Register Your Details"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>

        <!-- INPUT GROUP -->
        <VBox alignment="CENTER" spacing="18">

            <!-- NAME -->
            <VBox spacing="6" alignment="CENTER">
                <Label text="Full Name" style="-fx-text-fill: #BDB7E2; -fx-font-size: 13px;"/>
                <TextField fx:id="nameField"
                           promptText="Enter your full name"
                           prefHeight="36"
                           maxWidth="250"
                           style="-fx-background-color: #2B2B44; -fx-text-fill: white; -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 0 12; -fx-font-size: 14px;"/>
            </VBox>

            <!-- DEPARTMENT -->
            <VBox spacing="6" alignment="CENTER">
                <Label text="Department" style="-fx-text-fill: #BDB7E2; -fx-font-size: 13px;"/>
                <ComboBox fx:id="departmentCombo"
                          editable="true"
                          promptText="Enter your department"
                          prefHeight="36"
                          maxWidth="250"
                          style="-fx-background-color: #2B2B44; -fx-text-fill: white; -fx-background-radius: 10; -fx-border-radius: 10; -fx-font-size: 14px;"/>
            </VBox>

        </VBox>

        <Label fx:id="errorLabel" style="-fx-text-fill: #FB7185; -fx-font-size: 13px;"/>

        <Button fx:id="registerButton"
                text="Register"
                prefHeight="40"
                maxWidth="250"
                onAction="#handleRegister"
                style="-fx-background-color: linear-gradient(to right, #7C3AED, #5B21B6); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 14;"/>

    </VBox>

</StackPane>