<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:id="root"
            style="
                -fx-background-color: linear-gradient(to bottom right, #141423, #4C1D95);
            ">

    <!-- Top bar -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="10"
              style="
                  -fx-background-color: transparent;
                  -fx-padding: 18 30;
              ">

            <Label text="UG"
                   style="
                       -fx-font-size: 18px;
                       -fx-font-weight: bold;
                       -fx-text-fill: #DDD6FE;
                       -fx-background-color: #312E81;
                       -fx-padding: 6 12;
                       -fx-background-radius: 10;
                   "/>

            <Label text="UniGrade"
                   style="
                       -fx-font-size: 18px;
                       -fx-font-weight: bold;
                       -fx-text-fill: #EDE9FE;
                   "/>
        </HBox>
    </top>

    <!-- Content -->
    <center>
        <AnchorPane fx:id="contentArea"
                    style="-fx-background-color: transparent;"/>
    </center>

</BorderPane>